# ══════════════════════════════════════════════════════════════════════════
# RailPulse OSS — environment variables
# Copy to .env and adjust as needed.
# ══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://railpulse:railpulse@localhost:5432/railpulse

# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ── Anomaly detection ────────────────────────────────────────────────────
ANOMALY_POLL_INTERVAL=30
ANOMALY_WINDOW_SIZE=60
ANOMALY_THRESHOLD=0.6

# ── RAG ───────────────────────────────────────────────────────────────────
RAG_TOP_K=5
